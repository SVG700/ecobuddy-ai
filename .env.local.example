# Google Gemini API Key
# Required for AI Coach chat assistant and Automated Weekly Report Generator.
# Get a key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=

# Supabase Project URL
# Required for remote database sync and authentication.
# Leave blank to run the app in offline local-sandbox mode (localStorage).
NEXT_PUBLIC_SUPABASE_URL=

# Supabase Public Anonymous Key
# Required for client-side API calls to Supabase.
# Leave blank to run the app in offline local-sandbox mode (localStorage).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
